---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
  <h1 class="text-3xl font-serif mb-6 text-stone-100 text-center">About</h1>
  
  <div class="max-w-4xl mx-auto">
    <p class="text-lg text-stone-300 mb-4 text-center">Just a little collections of all the wonderful things 🐧 made so far or is currently working on.</p>
    <div class="flex justify-center rounded-lg overflow-hidden gap-0">
        <img src="/coaster in the making.jpeg" class="w-1/3 h-auto" />
        <img src="/working_desk.jpeg" class="w-1/3 h-auto border-x-4 border-stone-900" />
        <img src="/about.jpeg" class="w-1/3 h-auto border-l-4 border-stone-900" />
    </div>
  </div>
</Layout>
