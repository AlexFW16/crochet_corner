---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;

const allImages = data.coverImage ? [data.coverImage, ...(data.images || [])] : (data.images || []);
---

<Layout title={data.title}>
  <div class="max-w-4xl mx-auto">
    <a href="/" class="text-amber-400 hover:underline text-sm">← Back to all projects</a>
    
    <h1 class="text-4xl font-serif mt-4 mb-4 text-stone-100">{data.title}</h1>
    
    <div class="mb-6">
      <span class={`px-3 py-1 text-sm rounded-full ${
        data.status === 'in-progress' ? 'bg-amber-900 text-amber-300' :
        data.status === 'completed' ? 'bg-green-900 text-green-300' :
        'bg-blue-900 text-blue-300'
      }`}>
        {data.status === 'in-progress' ? 'In Progress' :
         data.status === 'completed' ? 'Completed' :
         'Future'}
      </span>
    </div>
    
    {allImages.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        {allImages.map((img, idx) => (
          <div class="aspect-square bg-stone-700 rounded-lg overflow-hidden">
            <img src={img} alt={`${data.title} ${idx + 1}`} class="w-full h-full object-cover" />
          </div>
        ))}
      </div>
    )}
    
    {allImages.length === 0 && (
      <div class="aspect-video bg-stone-700 rounded-lg mb-8 flex items-center justify-center">
        <span class="text-8xl">🧶</span>
      </div>
    )}
    
    <div class="mb-8">
      <p class="text-lg text-stone-300">{data.shortDescription}</p>
    </div>
    
    {data.sources.length > 0 && (
      <div class="border-t border-stone-700 pt-6">
        <h2 class="text-xl font-serif mb-4 text-stone-100">Sources & Links</h2>
        <ul class="space-y-3">
          {data.sources.map(source => (
            <li class="flex items-center gap-2">
              <span class="text-sm bg-stone-700 px-2 py-0.5 rounded text-stone-400">{source.type}</span>
              <a href={source.url} target="_blank" rel="noopener" class="text-amber-400 hover:underline">{source.title}</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</Layout>